# Required: OpenRouter API key for AI chat and vision features
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenWeather API key for weather functionality
VITE_WEATHER_API_KEY=your_openweather_api_key_here

# Optional: NewsAPI key for news headlines
VITE_NEWS_KEY=your_newsapi_key_here
